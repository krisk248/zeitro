# Zeitro Production Configuration
# Set these in Coolify's environment variables UI

# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-secret-key-here

# REQUIRED: Your domain (with https)
CORS_ORIGINS=["https://zeitro.yourdomain.com"]

# REQUIRED: Set to true when using HTTPS
COOKIE_SECURE=true

# OPTIONAL: Set if using a subdomain (e.g. ".yourdomain.com" for cross-subdomain cookies)
# COOKIE_DOMAIN=

# OPTIONAL: Change exposed port (default 3000)
# ZEITRO_PORT=3000
